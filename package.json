{
  "name": "smart-tomato",
  "version": "1.1.0",
  "description": "一款极致优雅的智能番茄钟软件",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.wxm.smarttomato",
    "productName": "SmartTomato",
    "artifactName": "${productName}_v${version}_Setup.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "abiharomatu77-a11y",
        "repo": "SmartTomato"
      }
    ]
  },
  "author": "wxm",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
